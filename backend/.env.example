# ============================================
# FORGE FITNESS - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# MongoDB - Get free cluster at https://mongodb.com/atlas
MONGODB_URI=mongodb://localhost:27017/forge-fitness

# JWT Secret - Generate a random 64-char string
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_minimum_64_chars

# Anthropic AI - Get free API key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Email (for reminders) - Gmail with App Password
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
